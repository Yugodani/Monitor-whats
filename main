[32m+[m[32mfrom django.db import connection[m
[32m+[m[32mfrom django.shortcuts import redirect[m
[32m+[m[32mfrom django.urls import reverse[m
[32m+[m
[32m+[m
[32m+[m[32mclass MultiTenantMiddleware:[m
[32m+[m[32m    def __init__(self, get_response):[m
[32m+[m[32m        self.get_response = get_response[m
[32m+[m
[32m+[m[32m    def __call__(self, request):[m
[32m+[m[32m        if request.user.is_authenticated:[m
[32m+[m[32m            # Set tenant schema for authenticated users[m
[32m+[m[32m            schema_name = request.user.company.lower().replace(' ', '_').replace('-', '_')[m
[32m+[m[32m            connection.set_tenant(schema_name)[m
[32m+[m
[32m+[m[32m        response = self.get_response(request)[m
[32m+[m[32m        return response[m
