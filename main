[36m@@ -0,0 +1,25 @@[m
[32m+[m[32mfrom rest_framework_simplejwt.authentication import JWTAuthentication[m
[32m+[m[32mfrom rest_framework_simplejwt.exceptions import InvalidToken[m
[32m+[m[32mfrom django.db import connection[m
[32m+[m
[32m+[m
[32m+[m[32mclass MultiTenantJWTAuthentication(JWTAuthentication):[m
[32m+[m[32m    def authenticate(self, request):[m
[32m+[m[32m        header = self.get_header(request)[m
[32m+[m[32m        if header is None:[m
[32m+[m[32m            return None[m
[32m+[m
[32m+[m[32m        raw_token = self.get_raw_token(header)[m
[32m+[m[32m        if raw_token is None:[m
[32m+[m[32m            return None[m
[32m+[m
[32m+[m[32m        validated_token = self.get_validated_token(raw_token)[m
[32m+[m
[32m+[m[32m        # Set tenant schema based on user's company[m
[32m+[m[32m        user = self.get_user(validated_token)[m
[32m+[m[32m        if user and user.company:[m
[32m+[m[32m            # Create schema name from company (lowercase, no spaces)[m
[32m+[m[32m            schema_name = user.company.lower().replace(' ', '_').replace('-', '_')[m
[32m+[m[32m            connection.set_tenant(schema_name)[m
[32m+[m
[32m+[m[32m        return (user, validated_token)[m
